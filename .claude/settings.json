{
  "model": "opus",
  "extraKnownMarketplaces": {
    "datadog": {
      "source": {
	"source": "github",
	"repo": "DataDog/claude-marketplace"
      }
    }
  },
  "enabledPlugins": {
    "marketplace-auto-update@datadog-claude-plugins": true,
    "dd@datadog-claude-plugins": true,
    "gopls-lsp@claude-plugins-official": true,
    "advanced-query@datadog-claude-plugins": true,
    "feature@datadog-claude-plugins": true,
    "rapid@datadog-claude-plugins": true,
    "orgstore@datadog-claude-plugins": true,
    "writing@datadog-claude-plugins": true,
    "dd-octo-sts@datadog-claude-plugins": true,
    "atlas@datadog-claude-plugins": true
  },
  "effortLevel": "medium",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(go run *)",
      "Bash(ls *)",
      "Bash(colima *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(bzl test *)",
      "Bash(bzl build *)"
    ],
    "deny": [
      "Bash(bazel clean *)",
      "Bash(bzl clean *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
